# Runtime palette copies regenerated by ~/.config/sway/scripts/theme-selector.sh.
# Sources of truth live in ~/.config/sway/themes/<name>/foot-theme.ini and ARE tracked.
/.config/foot/foot-theme.ini

# Claude Code: private persona, memory, sessions, history, settings — NEVER in this public repo.
# Only kept out so far by `status.showUntrackedFiles no`; this is the real guard.
/.claude/
/CLAUDE.md

# Runtime waybar palette CSS — a symlink regenerated by theme-selector.sh into
# ~/.cache/sway-theming/. Same category as the foot-theme.ini above.
/.config/waybar/theme.css

# Editor/runtime scaffolding and backups — never the config of record.
/.config/waybar/*.backup*
/.config/waybar/*.skel

# nchat (WhatsApp TUI) runtime config — rewritten on exit, may hold session/PII.
# Its wired scripts live under ~/.config/sway/scripts/ and ARE tracked.
/.config/nchat/

# systemd user enable symlinks — generated by `systemctl --user enable`.
/.config/systemd/user/*.wants/

# Python bytecode caches from the sway/eww helper scripts.
__pycache__/
*.pyc
