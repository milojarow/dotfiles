#!/usr/bin/env bash
# mal-organizer-lobo — judgment layer for the Incoming organizer.
#
# Reads a digest on stdin, one file per line, TAB-separated:
#     INDEX<TAB>EXTENSION<TAB>FILENAME<TAB>HINT
# For video files HINT may carry live MAL search candidates ("MAL candidates:
# id 'title' (date, type, eps); ...") fetched by the caller, so the lobo picks
# the scrobble target from verified entries instead of recalling from memory.
# Returns a JSON move-plan on stdout:
#     {"decisions":[{"index":N,"type":"anime|manga|book|skip",
#                    "series_folder":"kebab","season":N|null,
#                    "scrobble_title":"MAL romaji title"|null}, ...]}
#
# Anti-fork-bomb locks (manada): CLAUDE_HEADLESS guard so the operator's hooks
# bail; no Agent tool (cannot spawn more lobos); single-shot structured output
# via --json-schema (no agentic loop to run away); cheap model.
set -uo pipefail

STATE="$HOME/.local/state/mal-organizer"
SCHEMA="$STATE/lobo-schema.json"
MODEL="${LOBO_MODEL:-sonnet}"

digest="$(cat)"
# nothing but whitespace -> empty plan
[[ -z "${digest//[$' \t\r\n']/}" ]] && { printf '{"decisions":[]}\n'; exit 0; }

SYS='You are the organizer "lobo" for a personal anime/manga library on Linux.
Input: a digest of newly downloaded files, one per line, TAB-separated:
INDEX<TAB>EXTENSION<TAB>FILENAME<TAB>HINT  (HINT may be empty).
For EACH line decide, using your knowledge of anime and manga titles:
- "type": "anime" for video episodes; "manga" for image comics (cbz/cbr/zip, or an
  EPUB that is image-based manga); "book" for text novels or light novels (a PDF, or
  an EPUB that is mostly text); "skip" if it is not library media. For an EPUB the
  HINT carries "images=N textpages=M": a high image count (about one per page) means
  image-based manga; very few images (just a cover) means a text novel => book.
  Combine the hint with the title.
- "series_folder": the canonical series name as lowercase kebab-case, collapsing
  season-specific titles to the base series (e.g. "Initial D" -> "initial-d";
  "Sousou no Frieren" -> "frieren"; "Shingeki no Kyojin" -> "attack-on-titan").
- "season": for anime, the installment identifier. Use an INTEGER for ordinary
  numbered seasons (infer from SxxExx or context). When a series uses NAMED
  installments instead of plain numbers (the Initial D "Stages" such as
  fifth-stage / final-stage; an Attack on Titan "Final Season"; named arcs/cours),
  output that canonical name as a lowercase kebab-case STRING (e.g. "final-stage"),
  and name ALL of that series'"'"'s installments consistently. A movie installment
  still counts as its installment (do not skip it). null for manga, book, or when
  unknown.
- "scrobble_title": ONLY for type=anime, else null. The exact ROMAJI title of the
  specific MyAnimeList entry this file'"'"'s installment scrobbles to, truncated
  before any ":" (e.g. season 3 of Mushoku Tensei is its own MAL entry titled
  "Mushoku Tensei III: Isekai Ittara Honki Dasu" -> "Mushoku Tensei III"). A MAL
  scrobbler matches by title, so a fansub tag like "S3" in a filename maps to the
  WRONG entry unless the library file carries the real entry title. When the HINT
  contains "MAL candidates:" (live search results: id, exact title, start date,
  media type, episode count), you MUST pick from those candidates - cross-check the
  file'"'"'s season/installment against start dates and episode counts - and copy
  the chosen title verbatim (up to the colon). NEVER output a title that is not
  among the candidates when candidates are present. If no candidate fits, or there
  is no candidates hint and you are not certain of the exact MAL title, use null.
The organizer renames the library hardlink to "<scrobble_title> - <ep>" when you
provide it; you only decide. Preserve each INDEX exactly. Return ONLY the JSON
object for the schema, one decision per input line.'

CLAUDE_HEADLESS=1 claude -p "$digest" \
  --append-system-prompt "$SYS" \
  --allowed-tools Read \
  --dangerously-skip-permissions \
  --exclude-dynamic-system-prompt-sections \
  --model "$MODEL" \
  --output-format json \
  --json-schema "$(cat "$SCHEMA")"
