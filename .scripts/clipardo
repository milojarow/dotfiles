#!/usr/bin/env bash
# clipardo: Copy file contents to the Wayland clipboard in Markdown format,
# respecting .gitignore patterns if enabled.
#
# Dependencies: bash, coreutils (cat, basename), file, git, wl-clipboard (wl-copy)
# Intended for Wayland environments.

set -euo pipefail

# Configuration
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/clipardo"
STATE_FILE="$CONFIG_DIR/state"   # contains "on" or "off"

# Ensure config directory exists
mkdir -p "$CONFIG_DIR"

# Read persistent toggle state (default: on)
if [[ -f "$STATE_FILE" ]]; then
    toggle_state=$(<"$STATE_FILE")
else
    toggle_state="on"
fi

show_help() {
    cat << EOF
Usage: clipardo [OPTIONS] [FILE or DIRECTORY]...
Copy file contents to the clipboard in Markdown format.

This script is intended for Wayland environments and depends on:
  - bash
  - file (for mime detection)
  - git (for .gitignore parsing)
  - wl-clipboard (provides wl-copy)

Options:
  -h, --help          Show this help message and exit.
  -r, --recursive     Process directories recursively.
  -i, --ignore        Override .gitignore for this run (include all files).
  -v, --verbose       Show progress [current/total].
  --toggle on|off     Enable or disable .gitignore support persistently.

If run without options and without arguments, this help is shown.

EOF
}

# Handle persistent toggle
if [[ "${1:-}" == "--toggle" ]]; then
    case "${2:-}" in
        on)
            echo "on" > "$STATE_FILE"
            echo "✅ .gitignore support ENABLED persistently."
            exit 0
            ;;
        off)
            echo "off" > "$STATE_FILE"
            echo "⚠️ .gitignore support DISABLED persistently."
            exit 0
            ;;
        *)
            echo "Usage: clipardo --toggle [on|off]"
            exit 1
            ;;
    esac
fi

# Parse flags
recursive=0
ignore_flag=0
verbose=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help; exit 0
            ;;
        -r|--recursive)
            recursive=1; shift
            ;;
        -i|--ignore)
            ignore_flag=1; shift
            ;;
        -v|--verbose)
            verbose=1; shift
            ;;
        *)
            break
            ;;
    esac
done

# Show help if no args and not recursive
if [[ $recursive -eq 0 && $# -eq 0 ]]; then
    show_help; exit 0
fi

# Determine effective .gitignore state for this run
if [[ $ignore_flag -eq 1 ]]; then
    effective_state="off"
else
    effective_state="$toggle_state"
fi

# Prepare inputs
if [[ $recursive -eq 1 ]]; then
    if [[ $# -eq 0 ]]; then
        inputs=(.)
    else
        inputs=("$@")
    fi
else
    inputs=("$@")
fi

# Gather list of candidate files
declare -a file_list
for point in "${inputs[@]}"; do
    if [[ -d "$point" ]]; then
        while IFS= read -r -d $'\0' f; do
            file_list+=("$f")
        done < <(find -P "$point" -type f -print0)
    else
        file_list+=("$point")
    fi
done

# Check if inside a Git repository
direct_root="$PWD"
if git -C "$direct_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    inside_git_repo=1
else
    inside_git_repo=0
fi

# Filter according to .gitignore state and skip Git internals
declare -a final_list
for f in "${file_list[@]}"; do
    # Skip the .git directory entirely
    if [[ "$f" == "$direct_root/.git"* || "$f" == ./.git* ]]; then
        continue
    fi
    if [[ "$effective_state" == "on" && $inside_git_repo -eq 1 && -f "$direct_root/.gitignore" ]]; then
        # Skip the .gitignore file itself
        if [[ "$(basename "$f")" == ".gitignore" ]]; then
            continue
        fi
        # Skip ignored files/directories
        if git -C "$direct_root" check-ignore -q -- "$f"; then
            continue
        fi
    fi
    final_list+=("$f")
done

# Warn if too many files
total=${#final_list[@]}
threshold=999
if [[ $total -gt $threshold ]]; then
    read -r -p "You are about to copy more than $total files, do you want to continue? [y/N] " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 1
    fi
fi

# Utility: get absolute path without resolving symlinks
get_abs_path() {
    local path="$1"
    if [[ "$path" = /* ]]; then
        echo "$path"
    else
        echo "$PWD/$path"
    fi
}

# Process a single file into the output buffer
output=""
process_file() {
    local file="$1"
    if [[ ! -e "$file" ]]; then
        echo "Warning: File not found: $file" >&2
        return
    fi

    local fullpath mime
    fullpath=$(get_abs_path "$file")
    mime=$(file --mime-type -b "$file")

    if [[ $mime == image/* || $mime == video/* || $mime == audio/* ]]; then
        file_output="$fullpath"
    else
        local filename extension lang content block
        filename=$(basename "$file")
        if [[ "$filename" == *.* && "$filename" != .* ]]; then
            extension="${filename##*.}"
            case "$extension" in
                sh|bash) lang="bash" ;;
                py)      lang="python" ;;
                js)      lang="javascript" ;;
                rb)      lang="ruby" ;;
                pl)      lang="perl" ;;
                php)     lang="php" ;;
                c)       lang="c" ;;
                cpp|cc|cxx) lang="cpp" ;;
                java)    lang="java" ;;
                html)    lang="html" ;;
                css)     lang="css" ;;
                rs)      lang="rust" ;;
                *)       lang="" ;;
            esac
        else
            lang=""
        fi

        content=$(<"$file")
        if [[ -n "$lang" ]]; then
            block=$(printf '``` %s
%s

```
' "$lang" "$content")
        else
            block=$(printf '```
%s

```
' "$content")
        fi
        file_output=$(printf '%s
%s' "$fullpath" "$block")
    fi

    if [[ -z "$output" ]]; then
        output="$file_output"
    else
        output+=$'\n\n'"$file_output"
    fi
}

# Process all files with optional verbose output
for idx in "${!final_list[@]}"; do
    file="${final_list[idx]}"
    num=$((idx+1))
    if [[ $verbose -eq 1 ]]; then
        echo "[$num/$total] Processing $file"
    fi
    process_file "$file"
done

# Send to Wayland clipboard
printf '%s' "$output" | wl-copy
echo "✅ Content copied to clipboard."

