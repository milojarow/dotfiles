#!/usr/bin/env bash
# clipardo: Copy file contents to the Wayland clipboard in Markdown format,
# respecting .gitignore patterns if enabled, skipping hidden by default.
#
# Dependencies: bash, coreutils (cat, basename), file, git, wl-clipboard (wl-copy)
# Intended for Wayland environments.

set -euo pipefail

# Configuration
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/clipardo"
STATE_FILE="$CONFIG_DIR/state"

mkdir -p "$CONFIG_DIR"

if [[ -f "$STATE_FILE" ]]; then
    toggle_state=$(<"$STATE_FILE")
else
    toggle_state="on"
fi

show_help() {
    cat << EOF
Usage: clipardo [OPTIONS] [FILE or DIRECTORY]...
Copy file contents to the clipboard in Markdown format.

Dependencies:
  bash
  file
  git
  wl-clipboard

Options:
  -h, --help          Show this help message and exit.
  -r, --recursive     Process directories recursively.
  -i, --ignore        Override .gitignore for this run.
  -v, --verbose       Show progress [current/total].
  -a, --all           Include hidden files/dirs.
  --toggle on|off     Enable/disable .gitignore persistently.
EOF
}

# Toggle handling
if [[ "${1:-}" == "--toggle" ]]; then
    case "${2:-}" in
        on) echo on > "$STATE_FILE"; echo "✅ .gitignore ENABLED."; exit 0 ;;  
        off) echo off > "$STATE_FILE"; echo "⚠️ .gitignore DISABLED."; exit 0 ;;  
        *) echo "Usage: clipardo --toggle [on|off]"; exit 1 ;;  
    esac
fi

# Flags
recursive=0; ignore_flag=0; verbose=0; all_flag=0
set_flag(){
    case "$1" in
        r) recursive=1 ;; i) ignore_flag=1 ;; v) verbose=1 ;; a) all_flag=1 ;; h) show_help; exit 0 ;;
        *) echo "Unknown -$1"; show_help; exit 1 ;;
    esac
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -?*) opts="${1#-}"; for ((i=0;i<${#opts};i++)); do set_flag "${opts:i:1}"; done; shift ;;  
        --recursive) recursive=1; shift ;;  
        --ignore) ignore_flag=1; shift ;;  
        --verbose) verbose=1; shift ;;  
        --all) all_flag=1; shift ;;  
        --help) show_help; exit 0 ;;  
        --toggle) break ;;  
        *) break ;;  
    esac
done

if [[ $recursive -eq 0 && $# -eq 0 ]]; then show_help; exit 0; fi

effective_state=$([[ $ignore_flag -eq 1 ]] && echo off || echo "$toggle_state")
inputs=( )
if [[ $recursive -eq 1 ]]; then inputs=( "${@:-.}" ); else inputs=( "$@" ); fi

file_list=()
for p in "${inputs[@]}"; do
    if [[ -d "$p" ]]; then
        while IFS= read -r -d $'\0' f; do file_list+=("$f"); done < <(find -P "$p" -type f -print0)
    else file_list+=("$p"); fi
done

# Git repo check
direct_root="$PWD"
if git -C "$direct_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then inside_git=1; else inside_git=0; fi

# Filter
final_list=()
for f in "${file_list[@]}"; do
    [[ "$f" == "$direct_root/.git"* ]] && continue
    rel="${f#$direct_root/}"
    if [[ $all_flag -eq 0 && ( "$rel" == .* || "$rel" == */.* ) ]]; then continue; fi
    if [[ "$effective_state" == "on" && $inside_git -eq 1 && -f "$direct_root/.gitignore" ]]; then
        [[ "$(basename "$f")" == ".gitignore" ]] && continue
        rel2="${rel#./}"
        git -C "$direct_root" check-ignore -q -- "$rel2" && continue
    fi
    final_list+=("$f")
done

total=${#final_list[@]}
if (( total > 999 )); then
    read -rp "You are about to copy $total files, proceed? [y/N] " ans
    [[ ! "$ans" =~ ^[Yy]$ ]] && echo "Aborted." && exit 1
fi

# Initialize output buffer
output=""

# Helpers
get_abs(){ [[ "$1" = /* ]] && echo "$1" || echo "$PWD/$1"; }

process_file(){
    local file="$1"
    [[ ! -e "$file" ]] && echo "Warn: $file not found" >&2 && return
    local full mime name ext lang content block
    full=$(get_abs "$file"); mime=$(file --mime-type -b "$file")
    if [[ $mime == image/* || $mime == video/* || $mime == audio/* ]]; then
        block="$full"
    else
        name=$(basename "$file"); ext="${name##*.}"; lang=""
        case "$ext" in sh|bash) lang=bash;; py) lang=python;; js) lang=javascript;; rs) lang=rust;; cpp|cc|cxx) lang=cpp;; html) lang=html;; css) lang=css;; php) lang=php;; rb) lang=ruby;; pl) lang=perl;; java) lang=java;; esac
        content=$(<"$file")
        if [[ -n "$lang" ]]; then
            block="\`\`\` $lang
$content

\`\`\`"
        else
            block="\`\`\`
$content

\`\`\`"
        fi
        block="$full
$block"
    fi
    [[ -z "$output" ]] && output="$block" || output+=$'\n\n'$block
}

# Loop through files
for idx in "${!final_list[@]}"; do
    ((num=idx+1))
    [[ $verbose -eq 1 ]] && echo "[$num/$total] Processing ${final_list[idx]}"
    process_file "${final_list[idx]}"
done

# Copy to clipboard
printf '%s' "$output" | wl-copy
echo "✅ Content copied"

