#!/bin/bash
# clipardo: Copia el contenido de archivos al portapapeles en formato markdown.
#
# Para archivos de texto:
#   - Primera línea: la ruta absoluta del archivo.
#   - Segunda línea: una "code fence" en markdown con un especificador de lenguaje
#     (derivado de la extensión, pero convertido al lenguaje correspondiente, por ejemplo,
#      "sh" se convierte en "bash" y "py" en "python"). Se agrega un espacio después de los
#      triple backticks.
#   - Luego: el contenido del archivo.
#   - Finalmente: una línea en blanco extra y el cierre de la "code fence".
#
# Para archivos no-texto (en modo no recursivo):
#   - Se copia únicamente la ruta absoluta.
#
# Uso:
#   clipardo [OPCIÓN]... [ARCHIVO o DIRECTORIO]...
#
# Opciones:
#   -h, --help         Muestra este mensaje de ayuda y sale.
#   -r, --recursive    Procesa recursivamente todos los archivos de texto dentro de los
#                      directorios indicados. Si no se especifica ningún argumento adicional,
#                      usa el directorio actual.
#
# Ejemplos:
#   clipardo ~/.bashrc
#   clipardo file1 /path/to/file2 ../file3
#   clipardo -r /etc/sway/
#   clipardo --recursive /etc/sway/ /another/dir file.txt

show_help() {
    cat << EOF
Uso: clipardo [OPCIÓN]... [ARCHIVO o DIRECTORIO]...
Copia el contenido de archivos al portapapeles en formato markdown.

Modos:
1. No recursivo:
   - Procesa los archivos (o paths) indicados.
   - Para archivos de texto:
       * Primera línea: ruta absoluta.
       * Segunda línea: code fence en markdown con lenguaje (detectado y mapeado a partir de la extensión).
       * Luego el contenido y, al final, una línea en blanco y cierre de code fence.
   - Para archivos no-texto, solo se copia la ruta.

2. Recursivo (-r, --recursive):
   - Si se pasan argumentos, cada argumento puede ser:
       * Un directorio: se buscarán recursivamente todos los archivos de texto en él.
       * Un archivo: se procesa directamente.
   - Si no se pasan argumentos después de la opción recursiva, se usa el directorio actual.

Opciones:
  -h, --help         Muestra este mensaje de ayuda y sale.
  -r, --recursive    Procesa recursivamente los archivos.

Ejemplos:
  clipardo ~/.bashrc
  clipardo file1 /path/to/file2 ../file3
  clipardo -r /etc/sway/
  clipardo --recursive /etc/sway/ /another/dir file.txt
EOF
}

# Comprueba si se pidió ayuda.
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi

recursive=0

# Comprueba si se ha especificado el modo recursivo.
if [[ "$1" == "-r" || "$1" == "--recursive" ]]; then
    recursive=1
    shift  # Quita la opción recursiva de los argumentos.
fi

output=""

process_file() {
    local file="$1"
    # Verifica que el archivo exista.
    if [ ! -e "$file" ]; then
        echo "Archivo no encontrado: $file" >&2
        return
    fi

    fullpath=$(realpath "$file")
    mime=$(file --mime-type -b "$file")

    # En modo recursivo solo procesamos archivos de texto.
    # En modo no recursivo, procesamos archivos de texto y no-texto.
    if [[ $mime == text/* ]]; then
        filename=$(basename "$file")
        if [[ "$filename" == *.* && "$filename" != .* ]]; then
            extension="${filename##*.}"
            # Mapeo de extensión a lenguaje.
            case "$extension" in
                sh) lang="bash" ;;
                bash) lang="bash" ;;
                py) lang="python" ;;
                js) lang="javascript" ;;
                rb) lang="ruby" ;;
                pl) lang="perl" ;;
                php) lang="php" ;;
                c) lang="c" ;;
                cpp|cc|cxx) lang="cpp" ;;
                java) lang="java" ;;
                html) lang="html" ;;
                css) lang="css" ;;
                rs) lang="rust" ;;
                *) lang="$extension" ;;
            esac
        else
            lang=""
        fi

        content=$(cat "$file")
        if [ -n "$lang" ]; then
            # Agregamos un espacio después de los triple backticks.
            block=$(printf '``` %s\n%s\n\n```\n' "$lang" "$content")
        else
            block=$(printf '```\n%s\n\n```\n' "$content")
        fi
        file_output=$(printf '%s\n%s' "$fullpath" "$block")
    else
        if [ $recursive -eq 0 ]; then
            file_output="$fullpath"
        else
            # En modo recursivo ignoramos archivos no-texto.
            return
        fi
    fi

    # Separa cada salida con dos saltos de línea.
    if [ -z "$output" ]; then
        output="$file_output"
    else
        output="$output\n\n$file_output"
    fi
}

if [ $recursive -eq 1 ]; then
    # Si se especificaron argumentos, úsalos como puntos de partida.
    if [ "$#" -eq 0 ]; then
        start_points=(.)
    else
        start_points=("$@")
    fi

    for point in "${start_points[@]}"; do
        if [ -d "$point" ]; then
            while IFS= read -r -d $'\0' file; do
                process_file "$file"
            done < <(find "$point" -type f -print0)
        elif [ -f "$point" ]; then
            process_file "$point"
        else
            echo "Ruta no válida: $point" >&2
        fi
    done
else
    # Modo no recursivo: procesa los argumentos directamente.
    if [ "$#" -eq 0 ]; then
        echo "No se especificó ningún archivo o directorio. Usa -h para ayuda."
        exit 1
    fi

    for file in "$@"; do
        process_file "$file"
    done
fi

# Copia la salida final al portapapeles usando wl-copy.
printf '%b' "$output" | wl-copy

echo "Contenido copiado al portapapeles."

