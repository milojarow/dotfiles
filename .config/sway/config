# Sway configuration – user custom behavior
# Minimal and validated.  No duplicate bindings, English comments only.

### Output
# output * bg /usr/share/backgrounds/sway/Sway_Wallpaper_Blue_1920x1080.png fill

### Appearance
corner_radius 15
for_window [app_id=".*"] dim_inactive 0.2

### Other settings --------------------------------------------------------
# Note: floating_modifier is defined in modes/default, not here

# Note: multimedia keybindings are defined in modes/default to avoid conflicts

include ~/.config/sway/definitions.d/theme.conf  # palette theme: color vars + client.* — see man palette-theming
include ~/.config/sway/config.d/*
include ~/.config/sway/modes/*
include ~/.config/sway/inputs/*

exec_always ~/.config/sway/scripts/random-wallpaper.sh

exec_always --no-startup-id ~/.config/sway/scripts/keyboard.sh

# Start systemd graphical session target
exec systemctl --user start graphical-session.target


exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=secrets

