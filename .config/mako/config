# Mako configuration - Dracula theme with bottom-right position

# Position
anchor=bottom-right

# No timeout - notifications stay until clicked
default-timeout=0

# Size and spacing
width=400
height=200
padding=20
margin=20

# Styling - Dracula theme colors with transparency and rounded corners
font=JetBrainsMono NF 10
text-color=#f8f8f2
background-color=#141a1b90
border-size=0
border-radius=15

# Do not disturb mode
[mode=do-not-disturb]
invisible=1

# Click/tap an nchat (WhatsApp) notification -> bring nchat to the current
# workspace + jump to the unread chat. nchat tags its notifications app-name
# "nchat" via desktop_notify_command in ~/.config/nchat/ui.conf.
[app-name="nchat"]
on-button-left=exec /home/milo/.config/sway/scripts/nchat-show.sh "$id"
on-touch=exec /home/milo/.config/sway/scripts/nchat-show.sh "$id"
