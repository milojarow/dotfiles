;; Arrow widget for repositioning other eww windows.
;; To target a different widget, edit the defwindow instance below:
;;   :window — the defwindow name to move
;;   :yuck   — path to the .yuck file that contains that defwindow

(defwidget widget-de-las-flechas [window yuck]
  (box :class "widget-mover"
       :orientation "v"
       :space-evenly false
       :spacing 4
    ;; Fine movement (10px)
    (button :class "mover-btn"
            :halign "center"
            :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} y 10"
            "↑")
    (box :orientation "h"
         :space-evenly false
         :spacing 4
      (button :class "mover-btn"
              :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} x -10"
              "←")
      (button :class "mover-btn"
              :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} x 10"
              "→"))
    (button :class "mover-btn"
            :halign "center"
            :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} y -10"
            "↓")
    ;; Coarse movement (50px)
    (button :class "mover-btn mover-btn--fast"
            :halign "center"
            :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} y 50"
            "↑↑")
    (box :orientation "h"
         :space-evenly false
         :spacing 4
      (button :class "mover-btn mover-btn--fast"
              :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} x -50"
              "←←")
      (button :class "mover-btn mover-btn--fast"
              :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} x 50"
              "→→"))
    (button :class "mover-btn mover-btn--fast"
            :halign "center"
            :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} y -50"
            "↓↓")
    ;; Jump movement (200px)
    (button :class "mover-btn mover-btn--jump"
            :halign "center"
            :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} y 200"
            "↑↑↑")
    (box :orientation "h"
         :space-evenly false
         :spacing 4
      (button :class "mover-btn mover-btn--jump"
              :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} x -200"
              "←←←")
      (button :class "mover-btn mover-btn--jump"
              :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} x 200"
              "→→→"))
    (button :class "mover-btn mover-btn--jump"
            :halign "center"
            :onclick "~/.config/eww/scripts/move-widget.sh ${window} ${yuck} y -200"
            "↓↓↓")))

(defwindow widget-de-las-flechas
  :monitor 0
  :geometry (geometry :x "100px"
                      :y "300px"
                      :anchor "bottom left")
  :stacking "fg"
  :focusable false
  (widget-de-las-flechas :window "wallpaper-cycle"
                          :yuck "~/.config/eww/widgets/wallpaper-cycle.yuck"))
