(defvar wp-revealed false)
(defvar wp-index 0)
(defvar wp-applied-index 0)

(deflisten wp-list :initial "[]"
  "~/.config/eww/scripts/wallpaper-cycle.sh list")

(defwidget wallpaper-cycle-widget []
  (box :class "wp-cycle" :orientation "h" :space-evenly false :spacing 18
       :valign "center"
    (box :class "wp-cycle-stack" :orientation "v" :space-evenly false :spacing 14
         :halign "center" :valign "center"
      (revealer :reveal wp-revealed :transition "crossfade" :duration "150ms"
        (button :class "wp-arrow"
                :onclick "~/.config/eww/scripts/wallpaper-cycle.sh prev"
          (label :text "↑")))
      (button :class "wp-dot"
              :onclick "~/.config/eww/scripts/wallpaper-cycle.sh dot-click"
              :onrightclick "~/.config/eww/scripts/wallpaper-cycle.sh cancel"
        (label :text "○"))
      (revealer :reveal wp-revealed :transition "crossfade" :duration "150ms"
        (button :class "wp-arrow"
                :onclick "~/.config/eww/scripts/wallpaper-cycle.sh next"
          (label :text "↓"))))
    (revealer :reveal wp-revealed :transition "slideright" :duration "200ms"
      (label :class "wp-name" :valign "center"
             :text {arraylength(wp-list) > 0 ? wp-list[wp-index].name : ""}))))

(defwindow wallpaper-cycle
  :monitor 0
  :geometry (geometry :x "570px" :y "310px" :anchor "top left")
  :stacking "bottom"
  :focusable false
  (wallpaper-cycle-widget))
