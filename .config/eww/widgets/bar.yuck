; ── Clipboard data ───────────────────────────────────────────────────────────
(deflisten clipboard
  :initial "{\"icon\": \"\", \"count\": 0}"
  `~/.config/eww/scripts/clipboard-subscribe.sh`)

; ── Wifi data ─────────────────────────────────────────────────────────────────
(deflisten wifi
  :initial "{\"icon\": \"\", \"ssid\": \"\", \"signal\": 0, \"ip\": \"\", \"freq\": \"\", \"security\": \"\", \"class\": \"disconnected\", \"connected\": false}"
  `~/.config/eww/scripts/wifi-subscribe.py`)

; ── Do-not-disturb data ──────────────────────────────────────────────────────
(deflisten dnd
  :initial "{\"active\": false, \"icon\": \"\"}"
  `~/.config/eww/scripts/dnd-subscribe.sh`)

; ── Gamma correction data ────────────────────────────────────────────────────
(deflisten gamma
  :initial "{\"active\": false, \"icon\": \"\"}"
  `~/.config/eww/scripts/gamma-subscribe.sh`)

; ── Idle inhibitor data ──────────────────────────────────────────────────────
(deflisten idle-inhibitor
  :initial "{\"active\": false, \"icon\": \"\"}"
  `~/.config/eww/scripts/idle-inhibitor-subscribe.sh`)

; ── Volume data ──────────────────────────────────────────────────────────────
(deflisten volume
  :initial "{\"text\": \"\", \"class\": \"\", \"volume\": 0, \"muted\": false, \"mic_muted\": false}"
  `~/.config/eww/scripts/volume-subscribe.py`)

; ── Memory pressure (PSI) data ───────────────────────────────────────────────
(deflisten mem-pressure
  :initial "{\"avg60\": 0, \"class\": \"normal\", \"active\": 0}"
  `~/.config/eww/scripts/mem-pressure-watch.py`)

; ── Workspace data ───────────────────────────────────────────────────────────
(deflisten workspaces
  :initial "[]"
  `~/.config/eww/scripts/workspace-subscribe.py`)

; ── Workspace widget ─────────────────────────────────────────────────────────
(defwidget bar-workspaces []
  (box :orientation "h"
       :spacing 0
       :class "bar-workspaces"
       :halign "start"
       :valign "center"
    (for ws in workspaces
      (button
        :class {"bar-ws"
              + (ws.num == -1 ? " bar-ws--scratchpad" : "")
              + (ws.focused     ? " bar-ws--focused"
              : ws.urgent      ? " bar-ws--urgent"
              : ws.has_windows ? " bar-ws--occupied"
              :                  " bar-ws--empty")}
        :onclick "${ws.cmd}"
        (box :orientation "h"
             :spacing 3
             :halign "center"
             :valign "center"
          (label :class "bar-ws-num"
                 :visible {ws.has_windows && ws.num != -1 && !ws.secret}
                 :text "${ws.num_icon}")
          (box :orientation "v"
               :halign "center"
               :valign "center"
               :spacing 0
            (label :class {ws.has_mid ? "bar-ws-icon" : "bar-ws-icon bar-ws-icon--solo"} :halign "center" :text "${ws.icon_top}")
            (label :class "bar-ws-icon" :halign "center" :text "${ws.icon_mid}" :visible {ws.has_mid})
            (label :class "bar-ws-icon" :halign "center" :text "${ws.icon_bot}" :visible {ws.has_bot})))))))


; ── Date widget (marquee) ────────────────────────────────────────────────────
; Cycle width (176) must match $bar-date-cycle in bar.scss
; 22 chars x 8px/char = 176px — trailing space ensures equal gaps between cycles
(defwidget bar-date []
  (overlay
    (box :width 170 :height 30 :class "bar-date-bg")
    (box :class "bar-date-strip"
         :orientation "h"
         :space-evenly false
         :halign "start"
         :valign "center"
         :hexpand false
      (box :width 176
        (label :class "bar-date" :text {formattime(EWW_TIME, "%a %e %b %Y %H:%M ")}))
      (box :width 176
        (label :class "bar-date" :text {formattime(EWW_TIME, "%a %e %b %Y %H:%M ")})))))

; ── Window title data ────────────────────────────────────────────────────────
(deflisten window-title
  :initial "{\"text\": \"\", \"css_class\": \"empty\"}"
  `~/.config/eww/scripts/window-title-subscribe.py`)

; Flash override — event-driven via inotifywait watching /tmp for the flash file.
; Zero CPU between events. Expiry handled by window-title-click-eww.sh (sleep+rm).
(deflisten wt-flash :initial ""
  `~/.config/eww/scripts/window-title-flash-watch.sh`)

; ── Recording indicator data ─────────────────────────────────────────────────
(deflisten recorder
  :initial '{"active": false}'
  `~/.config/eww/scripts/recorder-subscribe.sh`)

; ── Sway mode data ────────────────────────────────────────────────────────────
(deflisten sway-mode
  :initial "{\"name\": \"\", \"active\": false}"
  `~/.config/eww/scripts/sway-mode-subscribe.py`)

; ── Center zone: sway mode | recording indicator | window title ──────────────
(defwidget bar-center []
  (box :halign "center" :space-evenly false
    (label :class "bar-mode"
           :markup {sway-mode.name}
           :visible {sway-mode.active})
    (button :class "bar-recorder-center"
            :visible {!sway-mode.active && recorder.active}
            :onclick "echo stop > /tmp/eww-recorder"
            :tooltip "Recording — click to stop"
      (box :orientation "h" :space-evenly false :spacing 8 :valign "center"
        (label :class "bar-recorder-dot" :text "󰑊")
        (label :class "bar-recorder-label" :text "REC")))
    (button :class "bar-wintitle-btn"
            :visible {!sway-mode.active && !recorder.active}
            :onclick "~/.config/eww/scripts/window-title-click-eww.sh"
            :onrightclick "swaymsg -q exec '~/.config/eww/scripts/window-title-rename-eww.sh'"
      (label :class "bar-wintitle ${strlength(wt-flash) > 0 ? 'app-flash' : window-title.css_class}"
             :halign "center"
             :xalign 0.5
             :truncate true
             :text {strlength(wt-flash) > 0 ? wt-flash : window-title.text}))))

; ── Idle inhibitor button (inside module groups) ─────────────────────────────
(defwidget bar-idle-inhibitor []
  (button :class "bar-module bar-idle-inhibitor ${idle-inhibitor.active ? 'active' : ''}"
          :onclick "echo t > /tmp/eww-idle-inhibitor"
          :onrightclick "swaymsg -q exec '~/.config/sway/scripts/idle-timeout.sh'"
          :tooltip {idle-inhibitor.active ? "Idle inhibitor active — system will not sleep" : "Idle inhibitor inactive — system will sleep normally"}
    (label :text {idle-inhibitor.icon})))

; ── Do-not-disturb button (inside module groups) ─────────────────────────────
(defwidget bar-dnd []
  (button :class "bar-module bar-dnd ${dnd.active ? 'active' : ''}"
          :onclick "echo t > /tmp/eww-dnd"
          :onrightclick "~/.config/sway/scripts/dnd.sh restore && echo t > /tmp/eww-dnd"
          :tooltip {dnd.active ? "Do not disturb — notifications silenced" : "Notifications on"}
    (label :text {dnd.icon})))

; ── Gamma correction button (inside module groups) ───────────────────────────
(defwidget bar-gamma []
  (button :class "bar-module bar-gamma ${gamma.active ? 'active' : ''}"
          :onclick "echo t > /tmp/eww-gamma"
          :tooltip {gamma.active ? "Gamma correction on — warm display" : "Gamma correction off"}
    (label :text {gamma.icon})))

; ── Memory pressure indicator (inside module groups) ─────────────────────────
(defwidget bar-mem-pressure []
  (button :class "bar-module bar-mem-pressure bar-mem-pressure--${mem-pressure.class}"
          :visible {mem-pressure.active == 1}
          :tooltip "Memory pressure: ${mem-pressure.avg60}% (PSI avg60)"
    (label :text "")))

; ── Volume button (inside module groups) ─────────────────────────────────────
(defwidget bar-volume []
  (eventbox :onscroll "~/.config/eww/scripts/volume-scroll.sh {}"
    (button :class "bar-module bar-volume ${volume.class}"
            :onclick "pavucontrol"
            :onmiddleclick "pactl set-sink-mute @DEFAULT_SINK@ toggle"
      (box :orientation "h"
           :space-evenly false
           :spacing 5
           :valign "center"
        (label :class "bar-volume-icon"
               :valign "center"
               :text {volume.icon})
        (circular-progress :value {volume.volume}
                           :class "bar-volume-gauge"
                           :width 19
                           :height 19
                           :thickness 3
                           :start-at 75)))))

; ── Clipboard button (inside module groups) ──────────────────────────────────
(defwidget bar-clipboard []
  (button :class "bar-module bar-clipboard"
          :onclick "swaymsg -q exec '~/.config/sway/scripts/clipboard-manager.sh \"Roboto 11\"'"
          :onrightclick "swaymsg -q exec 'cliphist list | rofi -theme ~/.config/rofi/themes/coffee-metal -dmenu -font \"Roboto 11\" -p \"Delete item\" -lines 10 | cliphist delete'"
          :onmiddleclick "rm -f ~/.cache/cliphist/db"
          :tooltip "${clipboard.count} item(s) in clipboard"
    (label :text {clipboard.icon})))

; ── Wifi button (inside module groups) ───────────────────────────────────────
(defwidget bar-wifi []
  (button :class "bar-module bar-wifi ${wifi.class}"
          :onclick "swaymsg -q exec '~/.config/eww/scripts/wifi-toggle-popup.sh'"
    (label :text {wifi.icon})))

; ── Recording indicator (inside module groups) ──────────────────────────────
(defwidget bar-recorder []
  (button :class "bar-module bar-recorder"
          :visible {recorder.active}
          :onclick "echo stop > /tmp/eww-recorder"
          :tooltip "Recording — click to stop"
    (label :text "󰑊")))

; ── Module groups ─────────────────────────────────────────────────────────────
(defwidget bar-module-groups []
  (box :orientation "h"
       :space-evenly false
       :spacing 2
       :valign "center"
    (bar-mem-pressure)
    (bar-clipboard)
    (bar-wifi)
    (bar-idle-inhibitor)
    (bar-dnd)
    (bar-volume)
    (bar-gamma)))

(defwidget bar-tray []
  (box :class "bar-tray"
       :space-evenly false
    (systray :spacing 4
             :icon-size 18
             :halign "end"
             :hexpand false)))

; ── Bar layout ────────────────────────────────────────────────────────────────
(defwidget eww-bar-widget []
  (centerbox :orientation "h"
             :class "bar"
    ; Left zone
    (box :orientation "h" :space-evenly false
      (label :class "bar-left-icon" :text "")
      (bar-workspaces))
    ; Center zone — truly centered in the bar
    (bar-center)
    ; Right zone
    (box :orientation "h"
         :space-evenly false
         :halign "end"
      (bar-module-groups)
      (bar-tray)
      (box :width 8)
      (bar-date))))

; ── Bar window ────────────────────────────────────────────────────────────────
(defwindow eww-bar
  :monitor 0
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "100%"
                      :height "30px"
                      :anchor "top center")
  :stacking "fg"
  :exclusive true
  (eww-bar-widget))
