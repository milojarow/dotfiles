(deflisten bat-live :initial '{"capacity":0,"status":"Unknown"}'
  "~/.config/eww/scripts/battery-subscribe.sh")

(defwidget battery-widget []
  (box :class "battery-outer"
    (overlay
      ;; Layer 1: container shell
      (box :class "battery-container"
           :halign "fill"
           :valign "fill")

      ;; Layer 2: liquid fill (dynamic height, pinned to bottom)
      (box :class {bat-live.capacity <= 15
                   ? "battery-liquid critical"
                   : bat-live.capacity >= 95
                     ? "battery-liquid full"
                     : "battery-liquid"}
           :valign "end"
           :halign "fill"
           :style "min-height: ${bat-live.capacity * 2}px;")

      ;; Layer 3: bolt + percentage
      (box :class "battery-fg"
           :orientation "v"
           :valign "center"
           :halign "center"
           :space-evenly false
        (label :class "battery-bolt"
               :visible {bat-live.status == "Charging"}
               :text "")
        (label :class "battery-pct"
               :text "${bat-live.capacity}%")))))

(defwindow battery-window
  :monitor 0
  :geometry (geometry :x "874px"
                      :y "624px"
                      :anchor "bottom left")
  :stacking "bg"
  :focusable false
  (battery-widget))
