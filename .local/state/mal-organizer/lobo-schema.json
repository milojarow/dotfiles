{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "index": { "type": "integer", "description": "The INDEX from the input digest line" },
          "type": { "type": "string", "enum": ["anime", "manga", "book", "skip"] },
          "series_folder": { "type": "string", "description": "Canonical series name as lowercase kebab-case folder" },
          "season": { "type": ["integer", "null"], "description": "Season number for anime, null otherwise" }
        },
        "required": ["index", "type", "series_folder", "season"]
      }
    }
  },
  "required": ["decisions"]
}
