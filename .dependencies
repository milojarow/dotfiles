# Core dotfiles dependencies
# This file is read by install.sh to install required packages
# Lines starting with # are ignored
# Packages are installed via paru (handles both official repos and AUR)

# Window Manager & Core Components
sway
swayr
waybar
rofi
foot
mako
swaylock
swayidle
swaybg
xdg-desktop-portal-wlr
wob

# Screenshot & Recording
grim
slurp
grimshot
swappy
wf-recorder

# Clipboard
wl-clipboard
cliphist

# System Utilities
unzip
brightnessctl
playerctl
pulseaudio
pulsemixer
libnotify
jq
curl
imagemagick
inotify-tools

# Screenshot & display (swayimg required for freeze-and-crop screenshot mode)
swayimg

# Network management (nmcli used by eww WiFi widget, nm-applet, waybar network)
networkmanager
network-manager-applet

# Package update checker (checkupdates command used by waybar pacman module)
pacman-contrib

# Python graphics (pycairo — required by eww gauge-render.py for sysmonitor gauges)
python-cairo

# Hardware sensors (sensors -j used by eww cpu-gauge.sh for CPU temperature)
lm_sensors

# Clipboard persistence (keeps clipboard alive after source app closes)
wl-clip-persist

# Authentication agent (polkit GUI dialogs for mounting disks, sudo prompts, etc.)
polkit-gnome

# Secrets/keyring storage (gnome-keyring-daemon started in sway config)
gnome-keyring

# Auto-tiling for sway (autotiling or autotiling-rs — both guarded in autostart)
autotiling

# Terminal Utilities
btop
calcurse

# Fonts (required for icons in waybar/cheatsheet)
ttf-jetbrains-mono-nerd
ttf-font-awesome
otf-font-awesome

# Python dependencies (for custom scripts)
python
python-i3ipc
python-requests
python-dbus

# Emoji picker
bemoji
wl-ime-type-git

# Additional tools
nwg-wrapper
swaycwd
xdg-user-dirs

# Bluetooth
bluez
bluez-utils

# File manager
pcmanfm-gtk3

# For gsettings (GTK theme switching)
glib2
